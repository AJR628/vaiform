# Route gating. Debug routes are off by default.
# Set to 1 to enable diag routes: POST /diag/echo, /diag/*, /api/diag/headers, GET /api/diag/caption-smoke.
# Dev tooling that uses /diag/tts_state (e.g. web SPA TokenDrawer) requires this.
VAIFORM_DEBUG=0

# Backend API Sentry base layer (optional in this pass; worker/mobile are not wired yet).
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=1.0

# Read-only local/operator Sentry -> Codex incident bridge (not mounted in Express).
# Use a dedicated read-only Sentry token. Do not paste the token into chat.
SENTRY_BRIDGE_TOKEN=
SENTRY_BRIDGE_ORG_SLUG=
SENTRY_BRIDGE_PROJECT_SLUG=
SENTRY_BRIDGE_TIMEOUT_MS=5000
SENTRY_BRIDGE_MAX_RESULTS=5
