{
  "name": "vaiform",
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "@napi-rs/canvas": "^0.1.80",
    "@sentry/node": "^10.47.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "express": "^4.19.2",
    "express-rate-limit": "^8.2.1",
    "ffmpeg-static": "^5.2.0",
    "firebase-admin": "^12.6.0",
    "helmet": "^8.1.0",
    "node-fetch": "^3.3.2",
    "openai": "^4.104.0",
    "sharp": "^0.33.5",
    "stripe": "^18.4.0",
    "uuid": "^11.1.0",
    "zod": "^3.25.76"
  },
  "scripts": {
    "start": "node --import ./instrument.mjs server.js",
    "start:api": "node --import ./instrument.mjs server.js",
    "start:worker:finalize": "node story-finalize.worker.js",
    "sentry:verify": "node scripts/sentry.verify.mjs",
    "sentry:read": "node scripts/ops/sentry-reader.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check:netlify-redirects": "node scripts/check-no-netlify-redirects.mjs",
    "check:root-api-callers": "node scripts/check-no-root-api-callers.mjs",
    "check:hardcoded-backend-origins": "node scripts/check-no-hardcoded-backend-origins.mjs",
    "check:format:changed": "node scripts/check-format-changed.mjs",
    "lint": "eslint src/app.js src/routes/story.routes.js src/routes/caption.preview.routes.js src/routes/assets.routes.js src/routes/stripe.webhook.js src/controllers/checkout.controller.js src/http/respond.js src/middleware/requireAuth.js src/middleware/validate.middleware.js src/middleware/planGuards.js src/ops/sentry-reader/index.js server.js scripts/check-responses.js scripts/check-responses-changed.mjs scripts/ops/sentry-reader.mjs test/observability/sentry-reader.test.js",
    "lint:full": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "npm run test:contracts",
    "test:contracts": "node --test --test-concurrency=1 test/contracts/phase4a.contract.test.js",
    "test:observability": "node --test test/observability/*.test.js",
    "test:security": "node scripts/check-privilege-escalation.mjs",
    "prepare": "husky install",
    "check:responses": "node scripts/check-responses.js",
    "check:responses:changed": "node scripts/check-responses-changed.mjs",
    "load:finalize:baseline": "node scripts/load/finalize-scenario-baseline.mjs",
    "load:finalize:restart": "node scripts/load/finalize-scenario-worker-restart.mjs",
    "load:finalize:provider": "node scripts/load/finalize-scenario-provider-slowdown.mjs",
    "load:finalize:retry-storm": "node scripts/load/finalize-scenario-retry-storm.mjs",
    "report:finalize:thresholds": "node scripts/load/finalize-threshold-report.mjs",
    "smoke": "node scripts/smoke.mjs",
    "test:poster": "node scripts/test-poster.mjs",
    "test:caption-preview-contract": "node scripts/test-caption-preview-contract.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "eslint": "^9.33.0",
    "globals": "^16.3.0",
    "husky": "^8.0.0",
    "prettier": "^3.3.3"
  }
}
